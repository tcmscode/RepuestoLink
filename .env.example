# Local: levantá Postgres con  docker compose up -d
DATABASE_URL="postgresql://apppesados:apppesados@localhost:5432/apppesados?schema=public"

# Railway inyecta DATABASE_URL al agregar el plugin PostgreSQL

AUTH_SECRET="genera-un-secreto-largo-aleatorio-minimo-32-caracteres"
NEXTAUTH_URL="http://localhost:3000"

CRON_SECRET="secreto-para-cron-jobs"

# Comisión plataforma (default 2)
# COMMISSION_PERCENT=2

# ARCA/AFIP: mock en desarrollo (default). false = requiere certificados en vivo
AFIP_MOCK=true

# Automatización de altas: forzar sin esperar 50 solicitudes/mes
# ACCESS_AUTOMATION_ENABLED=true
# ACCESS_AUTOMATION_THRESHOLD=50

# Opcional: carpeta de facturas (en Railway montá un Volume en /app/uploads)
# UPLOAD_DIR="/app/uploads"
